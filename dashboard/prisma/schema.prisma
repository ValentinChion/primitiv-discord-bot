generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // When using Prisma Accelerate, uncomment the following line:
  // directUrl = env("DIRECT_DATABASE_URL")
}

enum Statut {
  PENDING
  DENIED
  VALIDATED
}

enum Type {
  DEMANDE
  PAIEMENT
  REMBOURSEMENT
}

model Demande {
  id          Int       @id @default(autoincrement())
  name            String    @unique
  userId          String
  discordUsername String?
  montant     Float
  description String
  type        Type
  statut      Statut    @default(PENDING)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  factureUrl  String? // URL Google Drive de la facture
  paiementId  Int? // ID de la demande de paiement associée (si type=REMBOURSEMENT)
  Paiement    Paiement? @relation(fields: [paiementId], references: [id])

  // Index pour les recherches rapides
  @@index([name])
  @@index([userId])
}

model Paiement {
  id         Int       @id @default(autoincrement())
  demandeId  Int       @unique
  Demande    Demande[]
  montant    Float
  factureUrl String? // URL Google Drive de la facture
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

enum Day {
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Stage {
  MAIN
  AFTER
}

model Slot {
  id          String   @id @default(cuid())
  stage       Stage    @default(MAIN)
  day         Day
  startTime   DateTime
  endTime     DateTime
  artistName  String
  note        String?
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PinCategory {
  SCENE
  FOOD
  SERVICES
  INFOS
  ACCESS
}

model MapPin {
  id          String      @id @default(cuid())
  label       String
  category    PinCategory
  lat         Float
  lon         Float
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Participant {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  phone     String
  createdAt DateTime @default(now())
}
